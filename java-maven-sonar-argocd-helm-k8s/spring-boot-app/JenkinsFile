pipeline {
  agent {
    docker {
      image 'naveenm323/maven-java17-docker'
      args '-u 1000:1000 -v /var/run/docker.sock:/var/run/docker.sock'
    }
  }

  environment {
    DOCKER_IMAGE = "naveenm323/ultimate-cicd:${BUILD_NUMBER}"
    GIT_USER_NAME = "naveenmarathi"
    REPO_NAME = "Jenkins-Zero-To-Hero"

    JAVA_HOME = '/opt/java/openjdk'
    PATH = "${JAVA_HOME}/bin:${env.PATH}"
  }

  stages {

    stage('Prepare Workspace') {
      steps {
        sh '''
          echo "Cleaning workspace safely..."
          rm -rf * || true
        '''
      }
    }

    stage('Checkout Source Code') {
      steps {
        git branch: 'main', url: 'https://github.com/iam-veeramalla/Jenkins-Zero-To-Hero.git'
      }
    }

    stage('Build Application') {
      steps {
        dir('java-maven-sonar-argocd-helm-k8s/spring-boot-app') {
          sh 'mvn clean package'
        }
      }
    }

    stage('Build Docker Image') {
      steps {
        dir('java-maven-sonar-argocd-helm-k8s/spring-boot-app') {
          sh 'docker build -t ${DOCKER_IMAGE} .'
        }
      }
    }

    stage('Push Docker Image') {
      steps {
        script {
          docker.withRegistry('https://index.docker.io/v1/', 'docker-cred') {
            sh "docker push ${DOCKER_IMAGE}"
          }
        }
      }
    }

    stage('Update Deployment Manifest') {
      steps {
        withCredentials([string(credentialsId: 'github', variable: 'GITHUB_TOKEN')]) {
          sh '''
            echo "===== Updating Deployment Manifest ====="

            git config --global --add safe.directory '*'

            # Always use fresh clone to avoid permission issues
            rm -rf temp-repo || true
            git clone https://${GITHUB_TOKEN}@github.com/${GIT_USER_NAME}/${REPO_NAME}.git temp-repo

            cd temp-repo
            git checkout main

            FILE="java-maven-sonar-argocd-helm-k8s/spring-boot-app-manifests/deployment.yml"

            echo "Updating image to ${DOCKER_IMAGE}"

            # Update image tag
            sed -i "s|image: .*|image: ${DOCKER_IMAGE}|g" $FILE

            # Git config
            git config user.email "naveenmarathi.xyz@gmail.com"
            git config user.name "Naveen Marathi"

            # Commit only if changes exist
            if git diff --quiet; then
              echo "No changes detected. Skipping commit."
            else
              git add .
              git commit -m "Update image to ${DOCKER_IMAGE}"
              git push origin main
            fi
          '''
        }
      }
    }
  }

  post {
    success {
      echo "✅ SUCCESS: Build, Push & Deployment Update Completed!"
    }
    failure {
      echo "❌ FAILURE: Pipeline failed!"
    }
  }
}
