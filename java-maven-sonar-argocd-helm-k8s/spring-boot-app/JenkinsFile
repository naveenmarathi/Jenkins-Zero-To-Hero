pipeline {
  agent {
    docker {
      image 'abhishekf5/maven-abhishek-docker-agent:v1'
      args '-u 1000:1000 -v /var/run/docker.sock:/var/run/docker.sock'
    }
  }

  environment {
    SONAR_URL = "http://34.204.100.100:9000"
    DOCKER_IMAGE = "naveenm323/ultimate-cicd:${BUILD_NUMBER}"
    GIT_REPO_NAME = "Jenkins-Zero-To-Hero"
    GIT_USER_NAME = "naveenmarathi"
  }

  stages {

    stage('Prepare Workspace') {
      steps {
        // Safe cleanup to avoid deleteDir / permission issues
        sh '''
          echo "Cleaning workspace..."
          rm -rf * || true
        '''
      }
    }

    stage('Checkout') {
      steps {
        git branch: 'main', url: 'https://github.com/iam-veeramalla/Jenkins-Zero-To-Hero.git'
      }
    }

    stage('Build and Test') {
      steps {
        dir('java-maven-sonar-argocd-helm-k8s/spring-boot-app') {
          sh 'mvn clean package'
        }
      }
    }

    stage('Static Code Analysis') {
      steps {
        withCredentials([string(credentialsId: 'sonarqube', variable: 'SONAR_AUTH_TOKEN')]) {
          dir('java-maven-sonar-argocd-helm-k8s/spring-boot-app') {
            sh 'mvn sonar:sonar -Dsonar.login=$SONAR_AUTH_TOKEN -Dsonar.host.url=${SONAR_URL}'
          }
        }
      }
    }

    stage('Build and Push Docker Image') {
      steps {
        dir('java-maven-sonar-argocd-helm-k8s/spring-boot-app') {
          script {
            sh "docker build -t ${DOCKER_IMAGE} ."
            def dockerImage = docker.image("${DOCKER_IMAGE}")
            docker.withRegistry('https://index.docker.io/v1/', 'docker-cred') {
              dockerImage.push()
            }
          }
        }
      }
    }

    stage('Update Deployment File') {
      steps {
        withCredentials([string(credentialsId: 'github', variable: 'GITHUB_TOKEN')]) {
          sh '''
            echo "Updating deployment file safely..."

            # Use fresh clone to avoid broken .git issues
            rm -rf temp-repo || true
            git clone https://${GITHUB_TOKEN}@github.com/${GIT_USER_NAME}/${GIT_REPO_NAME}.git temp-repo
            cd temp-repo
            git checkout main

            git config user.email "abhishek.xyz@gmail.com"
            git config user.name "Abhishek Veeramalla"

            FILE="java-maven-sonar-argocd-helm-k8s/spring-boot-app-manifests/deployment.yml"

            # Replace image tag with current build
            sed -i "s|replaceImageTag|${BUILD_NUMBER}|g" $FILE

            # Commit only if changes exist
            if git diff --quiet; then
              echo "No changes detected. Skipping commit."
            else
              git add $FILE
              git commit -m "Update deployment image to version ${BUILD_NUMBER}"
              git push origin main
            fi
          '''
        }
      }
    }

  }

  post {
    success {
      echo "✅ SUCCESS: Build, Push & Deployment Update Completed!"
    }
    failure {
      echo "❌ FAILURE: Pipeline failed!"
    }
  }
}
