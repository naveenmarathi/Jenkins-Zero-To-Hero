pipeline {
  agent {
    docker {
      image 'naveenm323/maven-java17-docker'
      args '--user root -v /var/run/docker.sock:/var/run/docker.sock'
    }
  }

  environment {
    SONAR_URL = "http://34.204.100.100:9000"
    DOCKER_IMAGE = "naveenm323/ultimate-cicd:${BUILD_NUMBER}"
    GIT_REPO_NAME = "Jenkins-Zero-To-Hero"
    GIT_USER_NAME = "naveenmarathi"

    JAVA_HOME = '/opt/java/openjdk'
    PATH = "${JAVA_HOME}/bin:${env.PATH}"
  }

  stages {

    stage('Verify Environment') {
      steps {
        sh '''
          echo "===== VERIFY ENV ====="
          java -version
          mvn -version
          docker --version
        '''
      }
    }

    stage('Checkout Code') {
      steps {
        checkout([
          $class: 'GitSCM',
          branches: [[name: '*/main']],
          userRemoteConfigs: [[
            url: 'https://github.com/iam-veeramalla/Jenkins-Zero-To-Hero.git'
          ]]
        ])
      }
    }

    stage('Build Application') {
      steps {
        dir('java-maven-sonar-argocd-helm-k8s/spring-boot-app') {
          sh 'mvn clean package'
        }
      }
    }

    stage('SonarQube Analysis') {
      steps {
        withCredentials([string(credentialsId: 'sonarqube', variable: 'SONAR_AUTH_TOKEN')]) {
          dir('java-maven-sonar-argocd-helm-k8s/spring-boot-app') {
            sh '''
              mvn sonar:sonar \
                -Dsonar.projectKey=spring-boot-demo \
                -Dsonar.host.url=${SONAR_URL} \
                -Dsonar.login=${SONAR_AUTH_TOKEN}
            '''
          }
        }
      }
    }

    stage('Build Docker Image') {
      steps {
        dir('java-maven-sonar-argocd-helm-k8s/spring-boot-app') {
          sh 'docker build -t ${DOCKER_IMAGE} .'
        }
      }
    }

    stage('Push Docker Image') {
      steps {
        script {
          docker.withRegistry('https://index.docker.io/v1/', 'docker-cred') {
            sh "docker push ${DOCKER_IMAGE}"
          }
        }
      }
    }

    stage('Update Deployment File') {
      steps {
        withCredentials([string(credentialsId: 'github', variable: 'GITHUB_TOKEN')]) {
          sh '''
            echo "===== UPDATE DEPLOYMENT FILE ====="

            # Fix Git issues inside Docker
            git config --global --add safe.directory '*'

            # Move to correct branch
            git checkout main

            # Sync with remote
            git pull origin main --rebase

            # Set Git identity
            git config user.email "naveenmarathi.xyz@gmail.com"
            git config user.name "Naveen Marathi"

            FILE="java-maven-sonar-argocd-helm-k8s/spring-boot-app-manifests/deployment.yml"

            # Only update if placeholder exists (prevents empty commits)
            if grep -q "replaceImageTag" $FILE; then
              echo "Updating deployment file..."

              sed -i "s/replaceImageTag/${BUILD_NUMBER}/g" $FILE

              git add $FILE
              git commit -m "Update image tag to ${BUILD_NUMBER}"

              git push https://${GITHUB_TOKEN}@github.com/${GIT_USER_NAME}/${GIT_REPO_NAME} main
            else
              echo "No placeholder found. Skipping commit & push ✅"
            fi
          '''
        }
      }
    }
  }

  post {
    success {
      echo "✅ SUCCESS: Pipeline completed!"
    }
    failure {
      echo "❌ FAILURE: Pipeline failed!"
    }
  }
}
